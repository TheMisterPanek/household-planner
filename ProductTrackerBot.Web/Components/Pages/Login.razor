@page "/login"
@using ProductTrackerBot.Services
@inject LoginCodeStore CodeStore
@inject NavigationManager Nav
@inject IConfiguration Config
@rendermode InteractiveServer

<PageTitle>Sign in — Household Planner</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="card w-full max-w-md text-center space-y-6">
        <h1 class="text-2xl font-bold text-gray-900">Sign in</h1>
        <p class="text-gray-600 text-sm">
            Send this code to <strong>@(Config["BOT_USERNAME"] ?? "your Telegram bot")</strong> with <code class="bg-gray-100 px-1 rounded">/login &lt;code&gt;</code>
        </p>
        <div class="py-4">
            <span class="font-mono text-4xl tracking-widest text-indigo-600 select-all">@code_</span>
        </div>
        @if (expired_)
        {
            <button class="btn-primary" @onclick="RefreshAsync">Get new code</button>
        }
        else
        {
            <p class="text-sm text-gray-400">Code expires in @countdown_ s</p>
        }
    </div>
</div>

@code {
    private string code_ = string.Empty;
    private string token_ = string.Empty;
    private int countdown_ = 300;
    private bool expired_;
    private CancellationTokenSource cts_ = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        await StartAsync();
        StateHasChanged();
    }

    private async Task StartAsync()
    {
        cts_.Cancel();
        cts_ = new CancellationTokenSource();
        var ct = cts_.Token;

        code_ = CodeStore.GenerateCode(out token_);
        countdown_ = 300;
        expired_ = false;

        _ = CountdownLoopAsync(ct);
        _ = PollLoopAsync(ct);

        await Task.CompletedTask;
    }

    private async Task CountdownLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                countdown_--;
                if (countdown_ <= 0)
                {
                    expired_ = true;
                    await InvokeAsync(StateHasChanged);
                    return;
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        var capturedToken = token_;
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(2000, ct);
                if (CodeStore.TryGetSession(capturedToken, out _))
                {
                    // Redirect through the server endpoint to set the HttpOnly cookie
                    await InvokeAsync(() => Nav.NavigateTo($"/api/auth/complete?token={capturedToken}", forceLoad: true));
                    return;
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task RefreshAsync() => await StartAsync();
}
