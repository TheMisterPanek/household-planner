@page "/settings"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using ProductTrackerBot.Repositories
@inherits AuthenticatedPageBase

@inject IPreferenceRepository Prefs

<PageTitle>Settings — Household Planner</PageTitle>

<h1 class="text-2xl font-bold text-gray-900 mb-6">Settings</h1>

@if (_error is not null)
{
    <div class="text-red-600 text-sm mb-4">@_error</div>
}

<div class="max-w-sm space-y-5">
    <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-gray-700">Language</label>
        <select @bind="_language" class="border rounded px-3 py-2 text-sm w-36">
            <option value="en">EN</option>
            <option value="ru">RU</option>
            <option value="pl">PL</option>
        </select>
    </div>

    <div class="flex flex-col gap-1">
        <label class="text-sm font-medium text-gray-700">Expiry warning (days ahead)</label>
        <input type="number" min="1" max="30" @bind="_expiryDays"
               class="border rounded px-3 py-2 text-sm w-24" />
    </div>

    <div class="flex items-center gap-3">
        <button @onclick="SaveAsync"
                class="px-4 py-2 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700">
            Save
        </button>
        @if (_saved)
        {
            <span class="text-green-600 text-sm">&#10003; Settings saved.</span>
        }
    </div>
</div>

@code {
    private string _language = "en";
    private int _expiryDays = 3;
    private bool _saved;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        try
        {
            _language = await Prefs.GetLanguageAsync(Session.ChatId, CancellationToken.None) ?? "en";
            _expiryDays = await Prefs.GetExpiryThresholdAsync(Session.ChatId, CancellationToken.None);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task SaveAsync()
    {
        _error = null;
        _saved = false;
        try
        {
            await Prefs.SaveLanguageAsync(Session.ChatId, _language, CancellationToken.None);
            await Prefs.SetExpiryThresholdAsync(Session.ChatId, _expiryDays, CancellationToken.None);
            _saved = true;
            StateHasChanged();
            await Task.Delay(3000);
            _saved = false;
            StateHasChanged();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
