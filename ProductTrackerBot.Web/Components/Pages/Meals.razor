@page "/meals"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using ProductTrackerBot.Models
@using ProductTrackerBot.Repositories
@inherits AuthenticatedPageBase

@inject GroupRepository Groups
@inject MealRepository MealRepo
@inject MealIngredientRepository IngredientRepo
@inject MealStepRepository StepRepo

<PageTitle>Meals — Household Planner</PageTitle>

<h1 class="text-2xl font-bold text-gray-900 mb-4">Meals</h1>

@if (_error is not null)
{
    <div class="text-red-600 text-sm mb-4">@_error</div>
}

<div class="flex gap-6">
    <!-- Sidebar: meal list -->
    <div class="w-48 shrink-0">
        <button @onclick="OpenAddMeal"
                class="w-full mb-3 px-3 py-1.5 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700">
            + New meal
        </button>

        @if (_showAddMeal)
        {
            <form @onsubmit="AddMealAsync" @onsubmit:preventDefault
                  class="mb-3 flex flex-col gap-1">
                <input @bind="_newMealName" placeholder="Meal name"
                       class="border rounded px-2 py-1 text-sm w-full" />
                <div class="flex gap-1">
                    <button type="submit"
                            class="flex-1 px-2 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
                        Add
                    </button>
                    <button type="button" @onclick="() => _showAddMeal = false"
                            class="flex-1 px-2 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300">
                        Cancel
                    </button>
                </div>
            </form>
        }

        @if (_loading)
        {
            <p class="text-gray-400 text-xs">Loading…</p>
        }
        else
        {
            @foreach (var meal in _meals)
            {
                <div class="flex items-center justify-between py-1 px-2 rounded cursor-pointer @(_selected?.Id == meal.Id ? "bg-indigo-50" : "hover:bg-gray-50")">
                    @if (_confirmDeleteMealId == meal.Id)
                    {
                        <span class="text-xs text-red-700 truncate flex-1">Delete?</span>
                        <button @onclick="() => DeleteMealAsync(meal.Id)"
                                class="text-red-600 text-xs font-medium hover:text-red-800 mr-1">Yes</button>
                        <button @onclick="() => _confirmDeleteMealId = null"
                                class="text-gray-400 text-xs hover:text-gray-600">No</button>
                    }
                    else
                    {
                        <span @onclick="() => SelectMealAsync(meal)"
                              class="text-sm truncate flex-1 @(_selected?.Id == meal.Id ? "text-indigo-700 font-medium" : "text-gray-800")">
                            @meal.Name
                        </span>
                        <button @onclick="() => _confirmDeleteMealId = meal.Id"
                                class="text-red-300 text-xs hover:text-red-500 ml-1">✕</button>
                    }
                </div>
            }

            @if (_meals.Count == 0)
            {
                <p class="text-gray-400 text-xs text-center py-4">No meals yet.</p>
            }
        }
    </div>

    <!-- Detail panel -->
    @if (_selected != null)
    {
        <div class="flex-1 min-w-0">
            <!-- Meal name -->
            <div class="flex items-center gap-3 mb-5">
                @if (_editingName)
                {
                    <input @bind="_nameDraft" class="border rounded px-2 py-1 text-sm" />
                    <button @onclick="SaveNameAsync"
                            class="px-3 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
                        Save
                    </button>
                    <button @onclick="() => _editingName = false"
                            class="px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300">
                        Cancel
                    </button>
                }
                else
                {
                    <h2 class="text-lg font-semibold text-gray-900">@_selected.Name</h2>
                    <button @onclick="BeginEditName"
                            class="px-3 py-1 border rounded text-xs text-gray-600 hover:bg-gray-50">
                        Rename
                    </button>
                }
            </div>

            <!-- Ingredients -->
            <div class="mb-6">
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Ingredients</h3>
                    <button @onclick="ToggleAddIngredient"
                            class="px-2 py-1 border rounded text-xs text-gray-600 hover:bg-gray-50">
                        + Add
                    </button>
                </div>

                <table class="w-full text-sm border-collapse">
                    <thead>
                        <tr class="text-left text-gray-500 border-b text-xs">
                            <th class="py-1 pr-3">Name</th>
                            <th class="py-1 pr-3 w-24">Qty</th>
                            <th class="py-1 w-8"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ing in _ingredients)
                        {
                            @if (_confirmDeleteIngId == ing.Id)
                            {
                                <tr class="border-b bg-red-50">
                                    <td colspan="2" class="py-1.5 text-xs text-red-700">Delete "@ing.Name"?</td>
                                    <td class="py-1.5">
                                        <button @onclick="() => DeleteIngredientAsync(ing.Id)"
                                                class="text-red-600 text-xs font-medium mr-1 hover:text-red-800">Yes</button>
                                        <button @onclick="() => _confirmDeleteIngId = null"
                                                class="text-gray-400 text-xs hover:text-gray-600">No</button>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                <tr class="border-b hover:bg-gray-50">
                                    <td class="py-1.5 pr-3">@ing.Name</td>
                                    <td class="py-1.5 pr-3 text-gray-500">@(ing.Quantity ?? "—")</td>
                                    <td class="py-1.5">
                                        <button @onclick="() => _confirmDeleteIngId = ing.Id"
                                                class="text-red-300 text-xs hover:text-red-500">✕</button>
                                    </td>
                                </tr>
                            }
                        }
                        @if (_ingredients.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="py-3 text-gray-400 text-xs text-center">No ingredients yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (_showAddIngredient)
                {
                    <form @onsubmit="AddIngredientAsync" @onsubmit:preventDefault
                          class="mt-2 flex gap-2 flex-wrap items-end">
                        <input @bind="_ingName" placeholder="Name" required
                               class="border rounded px-2 py-1 text-sm min-w-28" />
                        <input @bind="_ingQty" placeholder="Qty (e.g. 500g)"
                               class="border rounded px-2 py-1 text-sm w-28" />
                        <button type="submit"
                                class="px-3 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
                            Add
                        </button>
                        <button type="button" @onclick="() => _showAddIngredient = false"
                                class="px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300">
                            Cancel
                        </button>
                    </form>
                }
            </div>

            <!-- Steps -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <h3 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Steps</h3>
                    <button @onclick="ToggleAddStep"
                            class="px-2 py-1 border rounded text-xs text-gray-600 hover:bg-gray-50">
                        + Add
                    </button>
                </div>

                <ol class="space-y-1">
                    @for (var i = 0; i < _steps.Count; i++)
                    {
                        var step = _steps[i];
                        var idx = i;

                        @if (_editingStepId == step.Id)
                        {
                            <li class="flex items-center gap-2 py-1">
                                <span class="text-gray-400 text-xs w-4">@(i + 1).</span>
                                <input @bind="_stepEditDraft" class="flex-1 border rounded px-2 py-0.5 text-sm" />
                                <button @onclick="() => SaveStepAsync(step.Id)"
                                        class="text-green-600 text-xs font-medium hover:text-green-800">Save</button>
                                <button @onclick="() => _editingStepId = null"
                                        class="text-gray-400 text-xs hover:text-gray-600">Cancel</button>
                            </li>
                        }
                        else if (_confirmDeleteStepId == step.Id)
                        {
                            <li class="flex items-center gap-2 py-1 bg-red-50 px-2 rounded">
                                <span class="text-xs text-red-700 flex-1 truncate">Delete step @(i + 1)?</span>
                                <button @onclick="() => DeleteStepAsync(step.Id)"
                                        class="text-red-600 text-xs font-medium hover:text-red-800">Yes</button>
                                <button @onclick="() => _confirmDeleteStepId = null"
                                        class="text-gray-400 text-xs hover:text-gray-600">No</button>
                            </li>
                        }
                        else
                        {
                            <li class="flex items-center gap-2 py-1 group hover:bg-gray-50 rounded px-1">
                                <span class="text-gray-400 text-xs w-4 shrink-0">@(i + 1).</span>
                                <span class="flex-1 text-sm text-gray-800">@step.Text</span>
                                <div class="flex gap-1 opacity-0 group-hover:opacity-100 shrink-0">
                                    <button @onclick="() => MoveStepUpAsync(idx)"
                                            disabled="@(idx == 0)"
                                            class="text-gray-400 text-xs hover:text-gray-700 disabled:opacity-30">↑</button>
                                    <button @onclick="() => MoveStepDownAsync(idx)"
                                            disabled="@(idx == _steps.Count - 1)"
                                            class="text-gray-400 text-xs hover:text-gray-700 disabled:opacity-30">↓</button>
                                    <button @onclick="() => BeginEditStep(step)"
                                            class="text-indigo-400 text-xs hover:text-indigo-600">✎</button>
                                    <button @onclick="() => _confirmDeleteStepId = step.Id"
                                            class="text-red-300 text-xs hover:text-red-500">✕</button>
                                </div>
                            </li>
                        }
                    }
                    @if (_steps.Count == 0)
                    {
                        <li class="text-gray-400 text-xs py-2">No steps yet.</li>
                    }
                </ol>

                @if (_showAddStep)
                {
                    <form @onsubmit="AddStepAsync" @onsubmit:preventDefault
                          class="mt-2 flex gap-2 items-end">
                        <input @bind="_stepDraft" placeholder="Step text" required
                               class="flex-1 border rounded px-2 py-1 text-sm" />
                        <button type="submit"
                                class="px-3 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
                            Add
                        </button>
                        <button type="button" @onclick="() => _showAddStep = false"
                                class="px-3 py-1 bg-gray-200 rounded text-xs hover:bg-gray-300">
                            Cancel
                        </button>
                    </form>
                }
            </div>
        </div>
    }
    else if (!_loading)
    {
        <div class="flex-1 flex items-center justify-center text-gray-400 text-sm">
            Select a meal from the sidebar, or add a new one.
        </div>
    }
</div>

@code {
    private List<Meal> _meals = [];
    private Meal? _selected;
    private List<MealIngredient> _ingredients = [];
    private List<MealStep> _steps = [];

    private bool _editingName;
    private string _nameDraft = "";

    private bool _showAddMeal;
    private string _newMealName = "";

    private bool _showAddIngredient;
    private string _ingName = "";
    private string _ingQty = "";

    private bool _showAddStep;
    private string _stepDraft = "";

    private int? _editingStepId;
    private string _stepEditDraft = "";

    private int? _confirmDeleteMealId;
    private int? _confirmDeleteIngId;
    private int? _confirmDeleteStepId;

    private bool _loading = true;
    private string? _error;

    private int _groupId;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        var group = await Groups.GetOrCreateAsync(Session.ChatId);
        _groupId = group.Id;
        await LoadMealsAsync();
    }

    private async Task LoadMealsAsync()
    {
        _loading = true;
        _error = null;
        try { _meals = await MealRepo.GetAllAsync(_groupId); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void OpenAddMeal() { _showAddMeal = true; _newMealName = string.Empty; }
    private void ToggleAddIngredient() { _showAddIngredient = !_showAddIngredient; _ingName = string.Empty; _ingQty = string.Empty; }
    private void ToggleAddStep() { _showAddStep = !_showAddStep; _stepDraft = string.Empty; }

    private async Task SelectMealAsync(Meal meal)
    {
        _selected = meal;
        _editingName = false;
        _showAddIngredient = false;
        _showAddStep = false;
        _editingStepId = null;
        _confirmDeleteIngId = null;
        _confirmDeleteStepId = null;
        await LoadDetailAsync();
    }

    private async Task LoadDetailAsync()
    {
        if (_selected == null) return;
        try
        {
            _ingredients = await IngredientRepo.GetAllAsync(_selected.Id);
            _steps = await StepRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task AddMealAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMealName)) return;
        try
        {
            var meal = await MealRepo.AddAsync(_groupId, _newMealName.Trim());
            _newMealName = "";
            _showAddMeal = false;
            await LoadMealsAsync();
            await SelectMealAsync(meal);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteMealAsync(int mealId)
    {
        try
        {
            await MealRepo.DeleteAsync(mealId);
            if (_selected?.Id == mealId) { _selected = null; _ingredients = []; _steps = []; }
            _confirmDeleteMealId = null;
            await LoadMealsAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void BeginEditName()
    {
        _nameDraft = _selected!.Name;
        _editingName = true;
    }

    private async Task SaveNameAsync()
    {
        if (_selected == null || string.IsNullOrWhiteSpace(_nameDraft)) return;
        var mealId = _selected.Id;
        try
        {
            await MealRepo.UpdateNameAsync(mealId, _nameDraft.Trim());
            _editingName = false;
            await LoadMealsAsync();
            _selected = _meals.FirstOrDefault(m => m.Id == mealId) ?? _selected;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task AddIngredientAsync()
    {
        if (string.IsNullOrWhiteSpace(_ingName) || _selected == null) return;
        try
        {
            var qty = string.IsNullOrWhiteSpace(_ingQty) ? null : _ingQty.Trim();
            await IngredientRepo.AddAsync(_selected.Id, _ingName.Trim(), qty);
            _ingName = "";
            _ingQty = "";
            _showAddIngredient = false;
            _ingredients = await IngredientRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteIngredientAsync(int ingId)
    {
        try
        {
            await IngredientRepo.DeleteAsync(ingId);
            _confirmDeleteIngId = null;
            _ingredients = await IngredientRepo.GetAllAsync(_selected!.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task AddStepAsync()
    {
        if (string.IsNullOrWhiteSpace(_stepDraft) || _selected == null) return;
        try
        {
            await StepRepo.AddAsync(_selected.Id, _stepDraft.Trim());
            _stepDraft = "";
            _showAddStep = false;
            _steps = await StepRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void BeginEditStep(MealStep step)
    {
        _editingStepId = step.Id;
        _stepEditDraft = step.Text;
        _confirmDeleteStepId = null;
    }

    private async Task SaveStepAsync(int stepId)
    {
        if (string.IsNullOrWhiteSpace(_stepEditDraft) || _selected == null) return;
        try
        {
            await StepRepo.UpdateAsync(stepId, _stepEditDraft.Trim());
            _editingStepId = null;
            _steps = await StepRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task DeleteStepAsync(int stepId)
    {
        try
        {
            await StepRepo.DeleteAsync(stepId);
            _confirmDeleteStepId = null;
            _steps = await StepRepo.GetAllAsync(_selected!.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task MoveStepUpAsync(int index)
    {
        if (index <= 0 || _selected == null) return;
        var above = _steps[index - 1];
        var current = _steps[index];
        try
        {
            await StepRepo.UpdateStepNumberAsync(above.Id, current.StepNumber);
            await StepRepo.UpdateStepNumberAsync(current.Id, above.StepNumber);
            _steps = await StepRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task MoveStepDownAsync(int index)
    {
        if (index >= _steps.Count - 1 || _selected == null) return;
        var current = _steps[index];
        var below = _steps[index + 1];
        try
        {
            await StepRepo.UpdateStepNumberAsync(current.Id, below.StepNumber);
            await StepRepo.UpdateStepNumberAsync(below.Id, current.StepNumber);
            _steps = await StepRepo.GetAllAsync(_selected.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
