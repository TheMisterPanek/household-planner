@page "/ai"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using ProductTrackerBot.Localization
@using ProductTrackerBot.Models
@using ProductTrackerBot.Repositories
@using ProductTrackerBot.Services
@inherits AuthenticatedPageBase

@inject GroupRepository Groups
@inject IAiQueryService AiService

<PageTitle>AI Query — Household Planner</PageTitle>

<h1 class="text-2xl font-bold text-gray-900 mb-4">AI Query</h1>

@if (_error is not null)
{
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded mb-4">
        @_error
    </div>
}

<div class="flex flex-col border rounded-lg overflow-hidden" style="height: 60vh">
    <div class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50">
        @foreach (var msg in _messages)
        {
            @if (msg.Role == "user")
            {
                <div class="flex justify-end">
                    <div class="bg-indigo-600 text-white rounded-xl rounded-br-sm px-4 py-2 max-w-xs text-sm">
                        @msg.Text
                    </div>
                </div>
            }
            else
            {
                <div class="flex justify-start">
                    <div class="bg-gray-100 text-gray-800 rounded-xl rounded-bl-sm px-4 py-2 max-w-sm text-sm whitespace-pre-wrap">
                        @msg.Text
                    </div>
                </div>
            }
        }
        @if (_thinking)
        {
            <div class="flex justify-start">
                <div class="bg-gray-100 text-gray-500 rounded-xl px-4 py-2 text-sm">
                    Thinking…
                </div>
            </div>
        }
        @if (_messages.Count == 0 && !_thinking)
        {
            <p class="text-gray-400 text-sm text-center mt-8">Ask a question about your shopping list or meal plan.</p>
        }
    </div>
    <form @onsubmit="SendAsync" @onsubmit:preventDefault
          class="flex gap-2 p-3 border-t bg-white">
        <input @bind="_input" @bind:event="oninput"
               @onkeydown="OnKeyDown"
               placeholder="Ask something…"
               disabled="@_thinking"
               class="flex-1 border rounded px-3 py-2 text-sm disabled:opacity-60" />
        <button type="submit"
                disabled="@(_thinking || string.IsNullOrWhiteSpace(_input))"
                class="px-4 py-2 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700 disabled:opacity-40">
            @(_thinking ? "…" : "Send")
        </button>
    </form>
</div>

@code {
    private record ChatMessage(string Role, string Text);

    private List<ChatMessage> _messages = [];
    private string _input = "";
    private bool _thinking;
    private string? _error;
    private long _groupId;
    private string _language = "English";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        var group = await Groups.GetOrCreateAsync(Session.ChatId);
        _groupId = group.Id;
        _language = LanguageNames.GetDisplayName(group.LanguageCode);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_thinking && !string.IsNullOrWhiteSpace(_input))
            await SendAsync();
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_input) || _thinking) return;
        _error = null;
        var question = _input.Trim();
        _messages.Add(new ChatMessage("user", question));
        _input = "";
        _thinking = true;
        StateHasChanged();
        try
        {
            var result = await AiService.AnswerAsync(Session.ChatId, _groupId, question, "", _language, CancellationToken.None);
            _messages.Add(new ChatMessage("bot", result.Text));
        }
        catch (Exception ex)
        {
            _error = ex.Message.Contains("401", StringComparison.Ordinal) || ex.Message.Contains("api key", StringComparison.OrdinalIgnoreCase)
                ? "AI service unavailable. Please check the OPENROUTER_API_KEY configuration."
                : ex.Message;
        }
        finally
        {
            _thinking = false;
        }
    }
}
