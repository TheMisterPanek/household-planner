<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HouseholdPlanner — Organise your home</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
        },
      },
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .glow {
      background: radial-gradient(ellipse 600px 400px at 50% 0%, rgba(99,102,241,0.15), transparent);
    }
    .icon-circle {
      @apply w-10 h-10 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400;
    }
  </style>
</head>
<body class="antialiased bg-gray-950 text-gray-100">

  <!-- Navbar -->
  <header id="navbar" class="fixed top-0 w-full bg-gray-950/80 backdrop-blur-md border-b border-white/5 z-50 transition-shadow">
    <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-white font-semibold tracking-tight">
        <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
        </svg>
        HouseholdPlanner
      </a>
      <div class="flex gap-8 text-sm text-gray-400">
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-white transition-colors">How it works</a>
        <a href="https://github.com/TheMisterPanek/household-planner" target="_blank" class="hover:text-white transition-colors">GitHub</a>
      </div>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative pt-40 pb-20 px-6 text-center overflow-hidden">
    <div class="glow absolute inset-0 -z-10"></div>
    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.1] max-w-2xl mx-auto text-white">
      Your household,<br>always organised.
    </h1>
    <p class="mt-6 text-lg text-gray-400 max-w-lg mx-auto leading-relaxed">
      Track groceries, plan meals, and manage your home inventory
      straight from Telegram — with a clean web workspace for everything else.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="https://t.me/${BOT_USERNAME}" target="_blank" class="inline-flex items-center gap-2 bg-indigo-500 text-white font-medium rounded-lg px-7 py-3 hover:bg-indigo-400 transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161l-1.97 9.294c-.146.658-.537.817-1.084.508l-3-2.211-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.334-.373-.121l-6.871 4.326-2.962-.924c-.643-.204-.657-.643.136-.953l11.572-4.461c.537-.194 1.006.131.831.929z"/></svg>
        Add to Telegram
      </a>
      <a href="/app" class="inline-flex items-center gap-2 border border-white/10 text-gray-300 font-medium rounded-lg px-7 py-3 hover:border-white/20 hover:text-white transition-colors">
        Open Workspace
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
    </div>

    <!-- Phone mockup -->
    <div class="mt-20 max-w-sm mx-auto">
      <div class="rounded-2xl border border-white/10 bg-gray-900/80 backdrop-blur p-1 shadow-2xl shadow-indigo-500/5">
        <div class="rounded-xl bg-gray-950 overflow-hidden">
          <!-- Telegram header bar -->
          <div class="bg-gray-800 px-4 py-2.5 flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 text-xs font-bold">HP</div>
            <div>
              <p class="text-white text-sm font-medium">HouseholdPlanner</p>
              <p class="text-gray-500 text-xs">bot</p>
            </div>
          </div>
          <!-- Chat messages -->
          <div class="px-4 py-5 space-y-3 text-left">
            <div class="flex justify-end">
              <div class="bg-indigo-500/20 rounded-2xl rounded-br-sm px-4 py-2 max-w-[80%]">
                <p class="text-sm text-gray-200">/buy milk, eggs, bread</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-gray-800 rounded-2xl rounded-bl-sm px-4 py-2 max-w-[80%]">
                <p class="text-sm text-gray-300">Added 3 items to your shopping list.</p>
                <p class="text-sm text-gray-300 mt-1">Use <span class="text-indigo-400">/list</span> to view all.</p>
              </div>
            </div>
            <div class="flex justify-end">
              <div class="bg-indigo-500/20 rounded-2xl rounded-br-sm px-4 py-2 max-w-[80%]">
                <p class="text-sm text-gray-200">/list</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="bg-gray-800 rounded-2xl rounded-bl-sm px-4 py-2 max-w-[80%]">
                <p class="text-sm font-medium text-white mb-1">Shopping list</p>
                <p class="text-sm text-gray-300">&#9744; milk</p>
                <p class="text-sm text-gray-300">&#9744; eggs</p>
                <p class="text-sm text-gray-300">&#9744; bread</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-sm font-semibold text-indigo-400 tracking-widest uppercase text-center mb-4">Features</h2>
      <p class="text-2xl font-bold text-white text-center mb-16">Everything your household needs</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Shopping list</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Track what your household needs. Add items with <code class="text-indigo-400">/buy</code>, mark done, edit quantities.</p>
        </div>
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Expiry tracking</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Log expiry dates when you buy. The bot alerts your group before food goes to waste.</p>
        </div>
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Price history</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Record prices at checkout. See how costs change over time and spot the best deals.</p>
        </div>
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Meal library</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Build a shared recipe library with ingredients and step-by-step instructions.</p>
        </div>
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">Weekly plan</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Assign meals to each day of the week. Everyone in the group sees what's cooking.</p>
        </div>
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-white/10 transition-colors">
          <div class="icon-circle mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>
          </div>
          <h3 class="font-semibold text-white mb-2">AI queries</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Ask anything in plain language — "what should I buy this week?" — and get a smart answer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="py-28 px-6 border-t border-white/5">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-sm font-semibold text-indigo-400 tracking-widest uppercase text-center mb-4">How it works</h2>
      <p class="text-2xl font-bold text-white text-center mb-16">Up and running in minutes</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="flex flex-col gap-4">
          <div class="w-9 h-9 rounded-full border border-indigo-500/30 text-indigo-400 flex items-center justify-center text-sm font-semibold shrink-0">1</div>
          <h3 class="font-semibold text-white">Add the bot to your group</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Search for <code class="text-indigo-400">@${BOT_USERNAME}</code> on Telegram and add it. The bot introduces itself and is ready to go.</p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="w-9 h-9 rounded-full border border-indigo-500/30 text-indigo-400 flex items-center justify-center text-sm font-semibold shrink-0">2</div>
          <h3 class="font-semibold text-white">Use commands from chat</h3>
          <p class="text-gray-400 text-sm leading-relaxed"><code class="text-indigo-400">/buy</code> to log a purchase, <code class="text-indigo-400">/list</code> to see what's needed, <code class="text-indigo-400">/meals</code> for recipes.</p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="w-9 h-9 rounded-full border border-indigo-500/30 text-indigo-400 flex items-center justify-center text-sm font-semibold shrink-0">3</div>
          <h3 class="font-semibold text-white">Open the web workspace</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Sign in with one tap — the bot sends you a code. Then manage everything from a clean dashboard.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-10 px-6 text-center text-sm text-gray-500">
    <p class="font-medium text-gray-400 mb-2">HouseholdPlanner</p>
    <p class="flex flex-wrap gap-4 justify-center">
      <span>EN / RU / PL</span>
      <a href="https://github.com/TheMisterPanek/household-planner" target="_blank" class="hover:text-gray-300 transition-colors">GitHub</a>
      <a href="https://t.me/${BOT_USERNAME}" target="_blank" class="hover:text-gray-300 transition-colors">@${BOT_USERNAME}</a>
    </p>
  </footer>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('shadow-lg', window.scrollY > 10);
    });
  </script>

</body>
</html>
